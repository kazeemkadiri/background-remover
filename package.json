{
  "name": "background-remover",
  "version": "1.0.0",
  "main": "backend/src/index.ts",
  "scripts": {
    "install:backend": "npm install --legacy-peer-deps",
    "watch": "tsc --watch",
    "backend": "node --watch build/index.js",
    "dev:backend": "concurrently \"npm run watch\" \"npm run backend\"",
    "dev:frontend": "npm start --prefix ./frontend",
    "check-types": "tsc",
    "prettier": "prettier --write .",
    "build:backend": "tsc",
    "build:frontend": "npm run build --prefix ./frontend",
    "build": "tsc && npm run build:frontend"
  },
  "repository": "https://github.com/kazeemkadiri/background-remover.git",
  "license": "MIT",
  "dependencies": {
    "argon2": "^0.40.1",
    "axios": "^1.13.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.0",
    "express-async-handler": "^1.2.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.20.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.19.9",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "concurrently": "^8.2.2",
    "eslint": "^9.39.2",
    "prettier": "3.2.5",
    "typescript": "^5.9.3"
  }
}
