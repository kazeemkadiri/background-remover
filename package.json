{
  "name": "background-remover",
  "version": "1.0.0",
  "main": "backend/src/index.ts",
  "scripts": {
    "install:backend": "npm install --legacy-peer-deps",
    "watch": "tsc --watch",
    "backend": "node --watch dist/app.js",
    "dev:backend": "concurrently \"npm run watch\" \"npm run backend\"",
    "dev:frontend": "npm start --prefix ./frontend",
    "check-types": "tsc",
    "prettier": "prettier --write .",
    "build:backend": "tsc",
    "build:frontend": "npm run build --prefix ./frontend",
    "build": "tsc && npm run build:frontend",
    "test": "jest",
    "test:watch": "jest --watchAll"
  },
  "repository": "https://github.com/kazeemkadiri/background-remover.git",
  "license": "MIT",
  "dependencies": {
    "@types/express-fileupload": "^1.5.1",
    "argon2": "^0.40.1",
    "axios": "^1.13.6",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.0",
    "express-async-handler": "^1.2.0",
    "express-fileupload": "^1.5.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.20.1",
    "serverless-http": "^4.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.19.9",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "concurrently": "^8.2.2",
    "eslint": "^9.39.2",
    "jest": "^30.3.0",
    "prettier": "3.2.5",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  },
  "workspaces": [
    "nodejs/node_modules/@imgly/background-removal-node"
  ]
}
